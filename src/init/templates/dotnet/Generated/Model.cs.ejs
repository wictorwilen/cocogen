// C# representation of the external item schema.
<% if (usesPrincipal && graphApiVersion === 'beta') { -%>
using <%= namespaceName %>.Core;

<% } -%>
namespace <%= schemaNamespace %>;

<% if (modelDocLines && modelDocLines.length) { -%>
<%- modelDocLines.join("\n") %>
<% } else { -%>
/// <summary>
/// Schema model generated from TypeSpec.
/// </summary>
<% } -%>
public sealed class <%= itemTypeName %>
{
<% for (const property of properties) { -%>
<% if (property.docLines && property.docLines.length) { -%>
<%- property.docLines.join("\n") %>
<% } -%>
    public <%= property.csType %> <%= property.csName %> { get; set; } = default!;

<% } -%>
    public string InternalId { get; set; } = "";
}
