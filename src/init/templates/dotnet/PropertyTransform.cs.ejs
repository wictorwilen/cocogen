/// <summary>
/// User-overridable transforms for schema fields.
/// 
/// PEOPLE ENTITIES (labels):
/// For properties marked with @coco.people decorators, the generated Transform<PropName> methods
/// automatically serialize using PeoplePayload.SerializePeopleEntity(), which:
/// - Serializes to JSON using System.Text.Json with DefaultIgnoreCondition.WhenWritingNull
/// - Strips Kiota metadata (AdditionalData, BackingStore, OdataType, @odata.type)
/// - Converts property names to camelCase
/// - Returns normalized JSON strings (no null values, no internal SDK properties)
/// 
/// You can override Transform<PropName> freely; the normalization happens inside SerializePeopleEntity.
/// 
/// Example:
///   protected override string? TransformAccountInfo(object row)
///   {
///       // Parse and customize the source data however you like
///       var account = new Microsoft.Graph.Beta.Models.UserAccountInformation
///       {
///           UserPrincipalName = RowParser.ParseString(row, new[] { "Email" })
///       };
///       // SerializePeopleEntity handles serialization + normalization automatically
///       return PeoplePayload.SerializePeopleEntity(account);
///   }
/// 
/// COLLECTIONS:
/// For collection properties, Transform<PropName> returns a List<string> of normalized JSON strings.
/// Each item in the collection is automatically serialized and normalized.
/// 
/// OTHER PROPERTIES (strings, dates, enums):
/// Override Transform<PropName> to customize validation, transformation, or parsing.
/// No automatic normalization applied (these are non-entity properties).
/// </summary>
