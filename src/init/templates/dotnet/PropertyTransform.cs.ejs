// Customize row-to-model property transforms.
namespace <%= schemaNamespace %>;

/// <summary>
/// User-overridable transforms for schema fields.
/// 
/// PEOPLE ENTITIES (labels):
/// For properties marked with @coco.people decorators, generated Transform<PropName> methods
/// return regular JSON strings from JsonSerializer.Serialize(...).
/// 
/// Final label cleanup happens later in ItemPayload via:
/// - PeoplePayload.SerializeStringLabel(...)
/// - PeoplePayload.SerializeCollectionLabel(...)
/// 
/// This keeps your overrides working with plain JSON and lets you deserialize/re-hydrate
/// intermediate values if you need advanced transform logic.
/// 
/// Normalization at the final stage includes:
/// - Strip Kiota metadata (AdditionalData, BackingStore, OdataType, @odata.type)
/// - Flatten useful AdditionalData fields
/// - Convert property names to camelCase
/// - Normalize date objects to yyyy-MM-dd
/// 
/// Example:
///   protected override string? TransformAccountInfo(object row)
///   {
///       // Parse and customize the source data however you like
///       var account = new Microsoft.Graph.Beta.Models.UserAccountInformation
///       {
///           UserPrincipalName = RowParser.ParseString(row, new[] { "Email" })
///       };
///       // Return regular JSON. Cleanup/normalization happens in ItemPayload later.
///       return JsonSerializer.Serialize(account, new JsonSerializerOptions
///       {
///           DefaultIgnoreCondition = JsonIgnoreCondition.WhenWritingNull,
///           Converters = { new JsonStringEnumConverter(JsonNamingPolicy.CamelCase) }
///       });
///   }
/// 
/// COLLECTIONS:
/// For collection properties, Transform<PropName> returns List<string> of regular JSON strings.
/// ItemPayload applies final cleanup to each item before Graph ingestion.
/// 
/// OTHER PROPERTIES (strings, dates, enums):
/// Override Transform<PropName> to customize validation, transformation, or parsing.
/// No automatic normalization applied (these are non-entity properties).
/// </summary>
public sealed class PropertyTransform : PropertyTransformBase
{
    // Override Transform<PropName> methods to customize mapping for any property.
}
