/**
 * Graph people entity helpers (generated).
 */

<% const hasLocalGraphTypes = graphTypes.some((type) => !type.sourcePackage); -%>

type UnknownObject = { [key: string]: unknown };

<% if (hasLocalGraphTypes) { -%>
type Open<T> = T & Record<string, unknown>;
<% } -%>

<% const usesStableGraphTypes = graphTypes.some((type) => type.sourcePackage === "v1"); -%>
<% const usesBetaGraphTypes = graphTypes.some((type) => type.sourcePackage === "beta"); -%>
<% if (usesStableGraphTypes) { -%>
import type * as MicrosoftGraph from "@microsoft/microsoft-graph-types";
<% } -%>
<% if (usesBetaGraphTypes) { -%>
import type * as MicrosoftGraphBeta from "@microsoft/microsoft-graph-types-beta";
<% } -%>

const isRecord = (value: unknown): value is UnknownObject =>
  typeof value === "object" && value !== null && !Array.isArray(value);

const parseJsonValue = (raw: string, fieldPath: string): unknown => {
  try {
    return JSON.parse(raw);
  } catch (error) {
    const message = error instanceof Error ? error.message : String(error);
    throw new Error(`${fieldPath} must be valid JSON (${message}).`);
  }
};

const normalizeSingleValue = (
  value: unknown,
  fieldName: string
): UnknownObject | undefined => {
  if (value === undefined || value === null) return undefined;
  if (typeof value !== "string") {
    throw new Error(`${fieldName} must be a JSON-encoded string.`);
  }
  const trimmed = value.trim();
  if (!trimmed) {
    throw new Error(`${fieldName} must be a non-empty JSON string.`);
  }
  const parsed = parseJsonValue(trimmed, fieldName);
  if (!isRecord(parsed)) {
    throw new Error(`${fieldName} must be a JSON object.`);
  }
  return parsed;
};

const normalizeCollectionValue = (
  value: unknown,
  fieldName: string
): Array<UnknownObject> | undefined => {
  if (value === undefined || value === null) return undefined;
  if (!Array.isArray(value)) {
    throw new Error(`${fieldName} must be an array of JSON strings.`);
  }

  const results: Array<UnknownObject> = [];
  value.forEach((entry, index) => {
    if (typeof entry !== "string") {
      throw new Error(`${fieldName}[${index}] must be a JSON-encoded string.`);
    }
    const trimmed = entry.trim();
    if (!trimmed) {
      throw new Error(`${fieldName}[${index}] must be a non-empty JSON string.`);
    }
    const parsed = parseJsonValue(trimmed, `${fieldName}[${index}]`);
    if (!isRecord(parsed)) {
      throw new Error(`${fieldName}[${index}] must be a JSON object.`);
    }
    results.push(parsed);
  });

  return results;
};

const ITEM_FACET_READ_ONLY_KEYS = [
  "createdBy",
  "createdDateTime",
  "lastModifiedBy",
  "lastModifiedDateTime",
  "source",
  "sources",
] as const;

const assertWritableItemFacet = (value: UnknownObject, fieldPath: string): void => {
  if (value["id"] !== undefined) {
    throw new Error(fieldPath + ".id is read-only and must not be provided.");
  }
  for (const key of ITEM_FACET_READ_ONLY_KEYS) {
    if (value[key] !== undefined) {
      throw new Error(fieldPath + "." + key + " is read-only and must not be provided.");
    }
  }
};

const validateSdkGraphObject = <T>(
  value: unknown,
  fieldPath: string,
  disallowReadonlyItemFacetFields = false
): T => {
  if (!isRecord(value)) {
    throw new Error(`${fieldPath} must be an object.`);
  }
  if (disallowReadonlyItemFacetFields) {
    assertWritableItemFacet(value, fieldPath);
  }
  return value as T;
};

const serializeSdkSingleValue = <T>(
  value: unknown,
  fieldName: string,
  disallowReadonlyItemFacetFields = false
): string | undefined => {
  const payload = normalizeSingleValue(value, fieldName);
  if (!payload) return undefined;
  return JSON.stringify(validateSdkGraphObject<T>(payload, fieldName, disallowReadonlyItemFacetFields));
};

const serializeSdkCollectionValue = <T>(
  payloads: Array<UnknownObject>,
  fieldName: string,
  disallowReadonlyItemFacetFields = false
): string[] =>
  payloads.map((payload, index) =>
    JSON.stringify(
      validateSdkGraphObject<T>(payload, `${fieldName}[${index}]`, disallowReadonlyItemFacetFields)
    )
  );

export type PeopleLabelSerializationOptions = {
  isCollection: boolean;
  collectionLimit: number | null;
  disallowReadonlyItemFacetFields: boolean;
};

export function serializeSdkPeopleLabelValue<T>(
  value: unknown,
  fieldName: string,
  options: PeopleLabelSerializationOptions
): string | string[] | undefined {
  if (options.isCollection) {
    const payloads = normalizeCollectionValue(value, fieldName);
    if (!payloads) return undefined;
    if (payloads.length === 0) return [];
    if (options.collectionLimit !== null && payloads.length > options.collectionLimit) {
      throw new Error(
        `${fieldName} supports at most ${options.collectionLimit} entries (received ${payloads.length}).`
      );
    }
    return serializeSdkCollectionValue<T>(payloads, fieldName, options.disallowReadonlyItemFacetFields);
  }

  return serializeSdkSingleValue<T>(value, fieldName, options.disallowReadonlyItemFacetFields);
}

<% if (hasLocalGraphTypes && graphEnums && graphEnums.length > 0) { -%>
<% for (const enumDef of graphEnums) { -%>
export type <%= enumDef.tsName %> =
<% for (const value of enumDef.values) { -%>
  | <%= JSON.stringify(value) %>
<% } -%>
;

const <%= enumDef.tsName %>Values = new Set([
<% for (const value of enumDef.values) { -%>
  <%= JSON.stringify(value) %>,
<% } -%>
]);

const is<%= enumDef.tsName %> = (value: unknown): value is <%= enumDef.tsName %> =>
  typeof value === "string" && <%= enumDef.tsName %>Values.has(value);

<% } -%>
<% } -%>

<% for (const type of graphTypes) { -%>
<% if (type.sourcePackage === "v1") { -%>
export type <%= type.alias %> = MicrosoftGraph.<%= type.alias %>;

<% } else if (type.sourcePackage === "beta") { -%>
export type <%= type.alias %> = MicrosoftGraphBeta.<%= type.alias %>;

<% } else { -%>
export type <%= type.alias %> = Open<
<% if (type.baseAlias) { -%>
  <%= type.baseAlias %> &
<% } -%>
{
<% for (const field of type.fields) { -%>
  <%= field.name %><%= field.optional ? "?" : "" %>: <%= field.optional ? `${field.tsType} | null` : field.tsType %>;
<% } -%>
}
>;

<% } -%>

<% if (!type.sourcePackage) { -%>
export function validate<%= type.alias %>(value: unknown, fieldPath: string): <%= type.alias %> {
<% if (type.baseAlias) { -%>
  validate<%= type.baseAlias %>(value, fieldPath);
<% } -%>
  if (!isRecord(value)) {
    throw new Error(`${fieldPath} must be an object.`);
  }
<% if (type.alias === "ItemFacet") { -%>
  if ((value as UnknownObject)["id"] !== undefined) {
    throw new Error(fieldPath + ".id is read-only and must not be provided.");
  }
  for (const key of ["createdBy", "createdDateTime", "lastModifiedBy", "lastModifiedDateTime", "source", "sources"]) {
    if ((value as UnknownObject)[key] !== undefined) {
      throw new Error(fieldPath + "." + key + " is read-only and must not be provided.");
    }
  }
<% } -%>
<% for (const field of type.fields) { -%>
  const <%= field.varName %> = (value as UnknownObject)[<%= JSON.stringify(field.name) %>];
  if (<%= field.varName %> === undefined || <%= field.varName %> === null) {
<% if (!field.optional) { -%>
    throw new Error(fieldPath + ".<%= field.name %> is required.");
<% } -%>
  } else {
<% if (field.isCollection) { -%>
    if (!Array.isArray(<%= field.varName %>)) {
      throw new Error(fieldPath + ".<%= field.name %> must be an array.");
    }
    (<%= field.varName %> as unknown[]).forEach((entry, entryIndex) => {
      if (!(<%= field.elementTypeCheck %>)) {
        throw new Error(fieldPath + ".<%= field.name %>[" + entryIndex + "] must be <%= field.elementExpected %>.");
      }
    });
<% } else { -%>
    if (!(<%= field.typeCheck %>)) {
      throw new Error(fieldPath + ".<%= field.name %> must be <%= field.expected %>.");
    }
<% } -%>
  }
<% } -%>
  return value as <%= type.alias %>;
}

<% } -%>

<% } -%>
