import { Client, ResponseType } from "@microsoft/microsoft-graph-client";
import type { AuthenticationProvider } from "@microsoft/microsoft-graph-client";

import type { ItemSource } from "../datasource/itemSource.js";

type ProfileSourceOptions = {
  webUrl: string;
  displayName: string;
  priority: "first" | "last";
};

export type ConnectorCoreOptions<Item> = {
  graphBaseUrls: {
    connectionProvisioning: string;
    schemaRegistration: string;
    itemIngestion: string;
    profileSourceRegistration: string;
  };
  contentCategory: string | null;
  schemaPayload: unknown;
  getAccessToken: () => Promise<string>;
  getItemId: (item: Item) => string;
  toExternalItem: (item: Item) => {
    id?: string;
    acl: Array<{ type: string; value: string; accessType: string }>;
    properties: Record<string, unknown>;
    content?: { type: string; value: string };
  };
  profileSource?: ProfileSourceOptions;
};

export type ProvisionOptions = {
  connectionId: string;
  connectionName: string;
  connectionDescription: string;
};

export type IngestOptions<Item> = {
  source: ItemSource<Item>;
  connectionId: string;
  dryRun?: boolean;
  limit?: number;
  batchSize?: number;
  retryAttempts?: number;
  verbose?: boolean;
  failFast?: boolean;
  toExternalItem: (item: Item) => unknown;
};

/**
 * Reusable connector core for provisioning, ingestion, and deletion.
 */
export class ConnectorCore<Item> {
  private readonly graphClient: Client;
  private readonly graphBaseUrls: {
    connectionProvisioning: string;
    schemaRegistration: string;
    itemIngestion: string;
    profileSourceRegistration: string;
  };
  private readonly contentCategory: string | null;
  private readonly schemaPayload: unknown;
  private readonly getAccessToken: () => Promise<string>;
  private readonly getItemId: (item: Item) => string;
  private readonly toExternalItem: (item: Item) => {
    id?: string;
    acl: Array<{ type: string; value: string; accessType: string }>;
    properties: Record<string, unknown>;
    content?: { type: string; value: string };
  };
  private readonly profileSource?: ProfileSourceOptions;

  constructor(options: ConnectorCoreOptions<Item>) {
    this.graphBaseUrls = options.graphBaseUrls;
    this.contentCategory = options.contentCategory;
    this.schemaPayload = options.schemaPayload;
    this.getAccessToken = options.getAccessToken;
    this.getItemId = options.getItemId;
    this.toExternalItem = options.toExternalItem;
    this.profileSource = options.profileSource;

    const authProvider: AuthenticationProvider = {
      getAccessToken: async () => this.getAccessToken(),
    };
    this.graphClient = Client.initWithMiddleware({ authProvider });
  }

  /**
   * Ensure the external connection exists (create if missing).
   */
  async ensureConnection(options: ProvisionOptions): Promise<void> {
    console.log("info: ensuring connection exists...");
    const existing = await this.graphRequest(
      "GET",
      `${this.graphBaseUrls.connectionProvisioning}/external/connections/${options.connectionId}`
    );
    if (existing.ok) {
      console.log("ok: connection exists");
      return;
    }
    if (existing.status !== 404) {
      const details = await readGraphError(existing);
      throw new Error(`Failed to check connection (HTTP ${formatStatus(existing)}): ${details}`);
    }

    const payload: any = {
      id: options.connectionId,
      name: options.connectionName,
      description: options.connectionDescription,
    };

    if (this.contentCategory) payload.contentCategory = this.contentCategory;

    const createUrl = `${this.graphBaseUrls.connectionProvisioning}/external/connections`;
    const create = await this.graphRequest("POST", createUrl, payload);
    if (!create.ok && create.status !== 409) {
      const details = await readGraphError(create);
      throw new Error(`Failed to create connection (HTTP ${formatStatus(create)}): ${details}`);
    }

    if (create.status === 409) {
      console.log("ok: connection already exists");
    } else {
      console.log("ok: connection created");
    }
  }

  /**
   * Patch the external connection schema using the generated payload.
   */
  async patchSchema(connectionId: string): Promise<void> {
    console.log("info: patching schema...");
    const schemaUrl = `${this.graphBaseUrls.schemaRegistration}/external/connections/${connectionId}/schema`;
    const res = await this.graphRequest("PATCH", schemaUrl, this.schemaPayload);
    if (!res.ok) {
      const details = await readGraphError(res);
      throw new Error(`Failed to patch schema (HTTP ${formatStatus(res)}): ${details}`);
    }

    await this.waitForSchemaReady(connectionId);
  }

  /**
   * Provision connection + schema.
   */
  async provision(options: ProvisionOptions): Promise<void> {
    await this.ensureConnection(options);
    await this.patchSchema(options.connectionId);
  }

  /**
   * Register the connection as a profile source and update its precedence (people connectors only).
   */
  async provisionProfileSource(connectionId: string): Promise<void> {
    if (!this.profileSource) {
      throw new Error("Profile source settings are missing.");
    }
    console.log("info: registering profile source...");
    await this.registerProfileSourceInternal(connectionId, this.profileSource);
  }

  /**
   * Register the connection as a profile source (people connectors only).
   */
  async registerProfileSource(connectionId: string): Promise<void> {
    await this.provisionProfileSource(connectionId);
  }

  /**
   * Remove the connection from profile source registrations (people connectors only).
   */
  async unregisterProfileSource(connectionId: string): Promise<void> {
    if (!this.profileSource) {
      throw new Error("Profile source settings are missing.");
    }
    await this.unregisterProfileSourceInternal(connectionId);
  }

  /**
   * Delete the external connection.
   */
  async deleteConnection(connectionId: string): Promise<void> {
    if (this.profileSource) {
      console.log("info: unregistering profile source...");
      await this.unregisterProfileSourceInternal(connectionId);
    }

    console.log("info: deleting connection...");
    const res = await this.graphRequest(
      "DELETE",
      `${this.graphBaseUrls.connectionProvisioning}/external/connections/${connectionId}`
    );
    if (!res.ok && res.status !== 404) {
      const details = await readGraphError(res);
      throw new Error(`Failed to delete connection (HTTP ${formatStatus(res)}): ${details}`);
    }
  }

  /**
   * Upsert a single item to Graph.
   */
  async putItem(connectionId: string, item: Item, verbose: boolean): Promise<void> {
    const itemId = this.getItemId(item);
    const url = `${this.graphBaseUrls.itemIngestion}/external/connections/${connectionId}/items/${encodeURIComponent(itemId)}`;

    const payload = this.toExternalItem(item);
    const payloadWithId = {
      ...payload,
      id: itemId,
      content: payload.content ?? { type: "text", value: "" },
    };
    console.log(`info: PUT item (id=${itemId})`);
    if (verbose) {
      console.log("verbose: PUT", url);
      console.log("verbose: payload", JSON.stringify(payloadWithId, null, 2));
    }

    const res = await this.graphRequest("PUT", url, payloadWithId);
    if (!res.ok) {
      const details = await readGraphError(res);
      throw new Error(`Failed to ingest item '${itemId}' (HTTP ${formatStatus(res)}): ${details}`);
    }
  }

  /**
   * Ingest items from a datasource.
   */
  async ingest(options: IngestOptions<Item>): Promise<void> {
    const batchSize = options.batchSize ?? 1;
    if (!Number.isInteger(batchSize) || batchSize < 1 || batchSize > 20) {
      throw new Error("Invalid batch size: expected integer between 1 and 20.");
    }
    const retryAttempts = options.retryAttempts ?? DEFAULT_ITEM_RETRY_ATTEMPTS;
    if (!Number.isInteger(retryAttempts) || retryAttempts < 0 || retryAttempts > MAX_ITEM_RETRY_ATTEMPTS) {
      throw new Error(`Invalid retry attempts: expected integer between 0 and ${MAX_ITEM_RETRY_ATTEMPTS}.`);
    }

    type PendingItem = { index: number; id: string; item: Item; attempt: number };

    let count = 0;
    let successCount = 0;
    const failures: Array<{ index: number; id: string; attempts: number; message: string }> = [];
    const pending: PendingItem[] = [];
    let retryQueue: PendingItem[] = [];

    const flushBatch = async (batch: PendingItem[]): Promise<void> => {
      if (batch.length === 0) {
        return;
      }

      for (const entry of batch) {
        if (entry.attempt === 0) {
          console.log(`info: ingesting item ${entry.index} (id=${entry.id})`);
          continue;
        }
        console.log(`info: retrying item ${entry.index} (id=${entry.id}) attempt ${entry.attempt}/${retryAttempts}`);
      }

      const results = await Promise.all(
        batch.map(async (entry) => {
          try {
            await this.putItem(options.connectionId, entry.item, Boolean(options.verbose));
            return { ...entry, success: true as const };
          } catch (error) {
            return { ...entry, success: false as const, error };
          }
        })
      );

      let firstError: unknown = null;
      for (const result of results) {
        if (result.success) {
          console.log(`ok: ingested item ${result.index} (id=${result.id})`);
          successCount++;
          continue;
        }

        const message = result.error instanceof Error ? result.error.message : String(result.error);
        console.error(`error: failed item ${result.index} (id=${result.id})`);

        if (!options.failFast && result.attempt < retryAttempts) {
          retryQueue.push({ index: result.index, id: result.id, item: result.item, attempt: result.attempt + 1 });
          continue;
        }

        failures.push({ index: result.index, id: result.id, attempts: result.attempt + 1, message });
        if (options.failFast && firstError === null) {
          firstError = result.error;
        }
      }

      if (firstError !== null) {
        throw firstError;
      }
    };

    for await (const item of options.source.getItems()) {
      if (options.limit && count >= options.limit) break;
      const index = count + 1;
      const itemId = this.getItemId(item as Item);
      if (!options.dryRun) {
        pending.push({ index, id: itemId, item: item as Item, attempt: 0 });
        if (pending.length >= batchSize) {
          const batch = pending.splice(0, pending.length);
          await flushBatch(batch);
        }
      } else if (options.verbose) {
        const payload = options.toExternalItem(item as Item) as any;
        const payloadWithId = {
          ...payload,
          id: itemId,
          content: payload?.content ?? { type: "text", value: "" },
        };
        console.log(`verbose: DRY RUN item ${index} (id=${itemId})`, JSON.stringify(payloadWithId, null, 2));
      }
      count++;
    }

    if (!options.dryRun) {
      const batch = pending.splice(0, pending.length);
      await flushBatch(batch);

      for (let retryAttempt = 1; retryAttempt <= retryAttempts && retryQueue.length > 0; retryAttempt++) {
        const queue = retryQueue;
        retryQueue = [];
        console.warn(`warn: retry pass ${retryAttempt}/${retryAttempts} for ${queue.length} item(s)`);

        for (let index = 0; index < queue.length; index += batchSize) {
          const batchSlice = queue.slice(index, index + batchSize);
          await flushBatch(batchSlice);
        }

        if (retryQueue.length > 0 && retryAttempt < retryAttempts) {
          const delayMs = computeRetryDelayMs(retryAttempt - 1);
          console.warn(`warn: waiting ${delayMs}ms before next retry pass`);
          await sleep(delayMs);
        }
      }

      if (retryQueue.length > 0) {
        for (const entry of retryQueue) {
          failures.push({
            index: entry.index,
            id: entry.id,
            attempts: entry.attempt,
            message: `exhausted retry queue after ${entry.attempt} attempt(s)`,
          });
        }
      }
    }

    if (!options.dryRun) {
      console.log(`ok: ingested ${successCount} item(s)`);
    } else {
      console.log(`ok: inspected ${count} item(s)`);
    }

    if (failures.length > 0) {
      console.warn(`warn: ${failures.length} item(s) failed`);
      for (const failure of failures) {
        console.warn(`warn: failed item ${failure.index} (id=${failure.id}) after ${failure.attempts} attempt(s) - ${failure.message}`);
      }
    }
  }

  private async graphRequest(method: string, url: string, body?: unknown): Promise<Response> {
    for (let attempt = 0; attempt <= MAX_RETRIES; attempt++) {
      try {
        const request = this.graphClient.api(url).responseType(ResponseType.RAW);
        const response = await executeGraphRequest(request, method, body);
        if (!shouldRetryStatus(response.status) || attempt === MAX_RETRIES) {
          return response;
        }

        const delay = computeRetryDelayMs(attempt, response.headers);
        console.warn(`warn: throttled (HTTP ${formatStatus(response)}) for ${method} ${url}, retrying in ${delay}ms`);
        await sleep(delay);
      } catch (error) {
        if (!isRetryableTransportError(error) || attempt === MAX_RETRIES) {
          throw error;
        }

        const delay = computeRetryDelayMs(attempt);
        const message = error instanceof Error ? error.message : String(error);
        console.warn(`warn: transient Graph transport error for ${method} ${url}: ${message}. Retrying in ${delay}ms`);
        await sleep(delay);
      }
    }

    throw new Error(`Graph request '${method} ${url}' exhausted retries.`);
  }

  private async listProfilePropertySettings(): Promise<
    Array<{ id: string; name?: string; prioritizedSourceUrls: string[] }>
  > {
    const res = await this.graphRequest(
      "GET",
      `${this.graphBaseUrls.profileSourceRegistration}/admin/people/profilePropertySettings`
    );
    if (!res.ok) {
      const details = await readGraphError(res);
      throw new Error(`Failed to list profile property settings (HTTP ${formatStatus(res)}): ${details}`);
    }
    const json = (await res.json()) as {
      value?: Array<{ id?: string; name?: string; prioritizedSourceUrls?: string[] }>;
    };
    return (json.value ?? [])
      .filter((entry) => typeof entry.id === "string")
      .map((entry) => ({
        id: entry.id as string,
        name: typeof entry.name === "string" ? entry.name : undefined,
        prioritizedSourceUrls: Array.isArray(entry.prioritizedSourceUrls) ? entry.prioritizedSourceUrls : [],
      }));
  }

  private async listProfileSources(): Promise<Array<{ sourceId: string }>> {
    const res = await this.graphRequest(
      "GET",
      `${this.graphBaseUrls.profileSourceRegistration}/admin/people/profileSources`
    );
    if (!res.ok) {
      const details = await readGraphError(res);
      throw new Error(`Failed to list profile sources (HTTP ${formatStatus(res)}): ${details}`);
    }
    const json = (await res.json()) as { value?: Array<{ sourceId?: string }> };
    return (json.value ?? [])
      .filter((entry) => typeof entry.sourceId === "string")
      .map((entry) => ({ sourceId: entry.sourceId as string }));
  }

  private async registerProfileSourceInternal(connectionId: string, profile: ProfileSourceOptions): Promise<void> {
    const sources = await this.listProfileSources();
    const exists = sources.some((source) => source.sourceId === connectionId);

    if (!exists) {
      const payload: any = {
        sourceId: connectionId,
        displayName: profile.displayName,
        webUrl: profile.webUrl,
      };

      const create = await this.graphRequest(
        "POST",
        `${this.graphBaseUrls.profileSourceRegistration}/admin/people/profileSources`,
        payload
      );
      if (!create.ok && create.status !== 409) {
        const details = await readGraphError(create);
        throw new Error(`Failed to register profile source (HTTP ${formatStatus(create)}): ${details}`);
      }
    }

    const sourceUrl = `${this.graphBaseUrls.profileSourceRegistration}/admin/people/profileSources(sourceId='${connectionId}')`;
    const settings = await this.listProfilePropertySettings();
    const precedence = settings.find((setting) => !setting.name);
    if (!precedence) {
      const create = await this.graphRequest(
        "POST",
        `${this.graphBaseUrls.profileSourceRegistration}/admin/people/profilePropertySettings`,
        { prioritizedSourceUrls: [sourceUrl] }
      );
      if (!create.ok) {
        const details = await readGraphError(create);
        throw new Error(`Failed to create profile property setting (HTTP ${formatStatus(create)}): ${details}`);
      }
      return;
    }

    const current = this.uniqueUrls(precedence.prioritizedSourceUrls);
    if (current.includes(sourceUrl)) {
      const isFirst = current[0] === sourceUrl;
      const isLast = current[current.length - 1] === sourceUrl;
      if ((profile.priority === "first" && isFirst) || (profile.priority === "last" && isLast)) {
        return;
      }
    }
    const existing = current.filter((value) => value !== sourceUrl);
    const updated = profile.priority === "first"
      ? this.uniqueUrls([sourceUrl, ...existing])
      : this.uniqueUrls([...existing, sourceUrl]);
    const res = await this.graphRequest(
      "PATCH",
      `${this.graphBaseUrls.profileSourceRegistration}/admin/people/profilePropertySettings/${precedence.id}`,
      {
        prioritizedSourceUrls: updated,
      }
    );
    if (!res.ok) {
      const details = await readGraphError(res);
      throw new Error(`Failed to update profile property setting ${precedence.id} (HTTP ${formatStatus(res)}): ${details}`);
    }
  }

  private async unregisterProfileSourceInternal(connectionId: string): Promise<void> {
    const sourceUrl = `${this.graphBaseUrls.profileSourceRegistration}/admin/people/profileSources(sourceId='${connectionId}')`;
    const settings = await this.listProfilePropertySettings();
    const precedence = settings.find((setting) => !setting.name);
    if (precedence) {
      const current = this.uniqueUrls(precedence.prioritizedSourceUrls);
      if (current.includes(sourceUrl)) {
        const updated = current.filter((value) => value !== sourceUrl);
        const res = await this.graphRequest(
          "PATCH",
          `${this.graphBaseUrls.profileSourceRegistration}/admin/people/profilePropertySettings/${precedence.id}`,
          {
            prioritizedSourceUrls: updated,
          }
        );
        if (!res.ok) {
          const details = await readGraphError(res);
          throw new Error(`Failed to update profile property setting ${precedence.id} (HTTP ${formatStatus(res)}): ${details}`);
        }
      }
    }

    const res = await this.graphRequest(
      "DELETE",
      `${this.graphBaseUrls.profileSourceRegistration}/admin/people/profileSources(sourceId='${connectionId}')`
    );
    if (!res.ok && res.status !== 404) {
      const details = await readGraphError(res);
      throw new Error(`Failed to delete profile source (HTTP ${formatStatus(res)}): ${details}`);
    }
  }

  private uniqueUrls(values: string[]): string[] {
    const seen = new Set<string>();
    const result: string[] = [];
    for (const value of values) {
      if (!value) continue;
      if (seen.has(value)) continue;
      seen.add(value);
      result.push(value);
    }
    return result;
  }

  private async waitForSchemaReady(connectionId: string): Promise<void> {
    const schemaUrl = `${this.graphBaseUrls.schemaRegistration}/external/connections/${connectionId}/schema`;
    console.log("info: waiting for schema provisioning...");
    for (let attempt = 0; attempt < SCHEMA_POLL_MAX_ATTEMPTS; attempt++) {
      const res = await this.graphRequest("GET", schemaUrl);
      if (!res.ok) {
        const details = await readGraphError(res);
        throw new Error(`Failed to read schema status (HTTP ${formatStatus(res)}): ${details}`);
      }
      const json = (await res.json()) as { status?: { state?: string } | string };
      const state = typeof json.status === "string" ? json.status : json.status?.state;
      if (!state) return;
      const normalized = state.toLowerCase();
      if (SCHEMA_READY_STATES.has(normalized)) return;
      if (!SCHEMA_PENDING_STATES.has(normalized)) {
        throw new Error(`Schema provisioning failed with status '${state}'.`);
      }
      console.log(`info: schema status '${state}' (${attempt + 1}/${SCHEMA_POLL_MAX_ATTEMPTS})`);
      await sleep(SCHEMA_POLL_DELAY_MS);
    }

    throw new Error("Schema provisioning timed out.");
  }
}

const SCHEMA_POLL_MAX_ATTEMPTS = 12;
const SCHEMA_POLL_DELAY_MS = 30000;
const MAX_RETRIES = 6;
const BASE_RETRY_DELAY_MS = 1000;
const MAX_RETRY_DELAY_MS = 30000;
const DEFAULT_ITEM_RETRY_ATTEMPTS = 2;
const MAX_ITEM_RETRY_ATTEMPTS = 10;
const SCHEMA_READY_STATES = new Set(["completed", "ready", "succeeded", "success"]);
const SCHEMA_PENDING_STATES = new Set(["inprogress", "pending", "running", "updating"]);

function sleep(ms: number): Promise<void> {
  return new Promise((resolve) => setTimeout(resolve, ms));
}

function formatStatus(res: Response): string {
  const text = res.statusText?.trim();
  return text ? `${res.status} ${text}` : `${res.status}`;
}

async function executeGraphRequest(
  request: ReturnType<Client["api"]>,
  method: string,
  body?: unknown
): Promise<Response> {
  switch (method) {
    case "GET":
      return (await request.get()) as Response;
    case "POST":
      return (await request.post(body ?? {})) as Response;
    case "PATCH":
      return (await request.patch(body ?? {})) as Response;
    case "PUT":
      return (await request.put(body ?? {})) as Response;
    case "DELETE":
      return (await request.delete()) as Response;
    default:
      throw new Error(`Unsupported Graph method '${method}'.`);
  }
}

function shouldRetryStatus(status: number): boolean {
  return status === 408 || status === 429 || (status >= 500 && status <= 599);
}

function isRetryableTransportError(error: unknown): boolean {
  if (!(error instanceof Error)) {
    return false;
  }

  const message = error.message.toLowerCase();
  return message.includes("fetch")
    || message.includes("network")
    || message.includes("timeout")
    || message.includes("socket")
    || message.includes("econnreset")
    || message.includes("econnrefused")
    || message.includes("etimedout")
    || message.includes("temporary failure");
}

function computeRetryDelayMs(attempt: number, headers?: Headers): number {
  const retryAfterMs = parseRetryDelayMs(headers);
  if (retryAfterMs !== null) {
    return Math.min(retryAfterMs, MAX_RETRY_DELAY_MS);
  }

  const exponential = Math.min(MAX_RETRY_DELAY_MS, BASE_RETRY_DELAY_MS * 2 ** attempt);
  const jitter = Math.floor(Math.random() * 250);
  return Math.min(MAX_RETRY_DELAY_MS, exponential + jitter);
}

function parseRetryDelayMs(headers?: Headers): number | null {
  if (!headers) {
    return null;
  }

  const msHeader = headers.get("x-ms-retry-after-ms")?.trim();
  if (msHeader) {
    const milliseconds = Number.parseInt(msHeader, 10);
    if (Number.isFinite(milliseconds)) {
      return Math.max(0, milliseconds);
    }
  }

  const retryAfter = headers.get("Retry-After")?.trim();
  if (!retryAfter) {
    return null;
  }

  const seconds = Number.parseInt(retryAfter, 10);
  if (Number.isFinite(seconds)) {
    return Math.max(0, seconds * 1000);
  }

  const absolute = Date.parse(retryAfter);
  if (Number.isFinite(absolute)) {
    return Math.max(0, absolute - Date.now());
  }

  return null;
}

async function readGraphError(res: Response): Promise<string> {
  const text = await res.text();
  if (!text) return "No response body.";
  try {
    const json = JSON.parse(text) as { error?: { code?: string; message?: string } };
    const message = json?.error?.message;
    const code = json?.error?.code;
    if (message) return code ? `${code}: ${message}` : message;
  } catch {
    // ignore
  }
  return text;
}