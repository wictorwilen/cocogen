{
  "name": "<%= projectName %>",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "provision": "npm run build && node dist/cli.js provision",
    "ingest": "npm run build && node dist/cli.js ingest",
<% if (isPeopleConnector) { -%>
    "register-profile-source": "npm run build && node dist/cli.js register-profile-source",
<% } -%>
    "delete": "npm run build && node dist/cli.js delete"
  },
  "dependencies": {
    "@azure/identity": "^4.13.0",
    "commander": "^14.0.2",
    "@microsoft/microsoft-graph-client": "^3.0.7",
<% if (isPeopleConnector) { -%>
    "@microsoft/microsoft-graph-types": "^2.43.1",
    "@microsoft/microsoft-graph-types-beta": "^0.44.0-preview",
<% } -%>
    "dotenv": "^17.2.3"<% if (inputFormat === "csv") { %>,
    "csv-parse": "^6.1.0"<% } %><% if (inputFormat !== "csv") { %>,
    "jsonpath-plus": "^10.3.0"<% } %><% if (inputFormat === "yaml") { %>,
    "yaml": "^2.8.1"<% } %>
  },
  "devDependencies": {
    "@wictorwilen/cocogen": "^1.0.0",
    "typescript": "^5.9.3",
    "@types/node": "^25.0.9"
  }
}
